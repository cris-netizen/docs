{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Puente OS",
  "colors": {
    "primary": "#363090",
    "light": "#9f8ec3",
    "dark": "#040404"
  },
  "favicon": {
    "light": "/images/Asset6@3x.png",
    "dark": "/images/Asset7@3x.png"
  },
  "logo": {
    "light": "/images/Asset4@3x.png",
    "dark": "/images/Asset5@3x.png",
    "href": "https://www.puente.xyz"
  },
  "navbar": {
    "links": [
      {
        "label": "Soporte",
        "href": "mailto:octavio@puente.xyz"
      }
    ],
    "primary": {
      "type": "button",
