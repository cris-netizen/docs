              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "Conceptos",
            "pages": [
              "essentials/conceptos",
              "essentials/glosario"
            ]
          },
          {
            "group": "Componentes",
            "pages": [
              "componentes/menu",
              "componentes/app-builder",
              "componentes/tables",
              "componentes/workflows",
              "componentes/agents"
            ]
          },
          {
            "group": "Recursos",
            "pages": [
              "recursos/atajos",
              "recursos/faq"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "linkedin": "https://www.linkedin.com/company/puente-os",
      "x": "https://x.com/puenteos"
    }
